{
  "expo": {
    "name": "PopliApp",
    "slug": "PopliApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/popli_logo.png",
    "scheme": "popliapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/popli_logo.png",
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.mahak2004.popliapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#12081E",
        "foregroundImage": "./assets/images/popli_logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.mahak2004.popliapp",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/custom_logo.png",
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PopliApp to access your camera to record videos and take photos.",
          "microphonePermission": "Allow PopliApp to access your microphone to record audio with your videos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging",
      "expo-video",
      "expo-audio",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "ndkVersion": "26.1.10909125"
          }
        }
      ],
      "expo-asset",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e1c05e5b-2493-4812-ac85-4e08a24d88a2"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}
